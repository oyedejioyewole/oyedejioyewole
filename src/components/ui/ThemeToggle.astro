---
import { buttonVariants } from "../../utils/variants";

import DesktopDuotone from "~icons/ph/desktop-duotone";

interface Props {
  class?: string;
}
---

<button
  class={buttonVariants({ iconOnly: true })}
  data-snap-cursor
  data-theme-toggle
  transition:persist
>
  <DesktopDuotone class="size-5" />

  <span class="sr-only">Using fallback theme</span>
</button>

<script>
  import SunDuotone from "~icons/ph/sun-duotone?raw&width=20px&height=20px";
  import MoonDuotone from "~icons/ph/moon-duotone?raw&width=20px&height=20px";

  let currentTheme =
    document.documentElement.attributes.getNamedItem("data-theme")?.value;

  const themeToggles = document.querySelectorAll<HTMLButtonElement>(
    "button[data-theme-toggle]",
  );

  function updateThemeIcons() {
    themeToggles.forEach((themeToggle) => {
      const themeIcon = themeToggle.querySelector("svg")!;

      themeIcon.outerHTML = (currentTheme === "dark"
        ? SunDuotone
        : MoonDuotone) as unknown as string;

      themeToggle.querySelector("span.sr-only")!.textContent = `Toggle ${
        currentTheme === "dark" ? "light" : "dark"
      } mode`;
    });
  }

  themeToggles.forEach((themeToggle) => {
    themeToggle.addEventListener("click", () => {
      currentTheme = currentTheme === "dark" ? "light" : "dark";
      document.dispatchEvent(
        new CustomEvent("set-theme", { detail: currentTheme }),
      ); // or pass `null` to clear the saved setting
      updateThemeIcons();
    });
  });

  updateThemeIcons();
</script>
