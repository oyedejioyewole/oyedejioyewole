---
import { YEAR } from "@netlify/cache";
import { getLiveCollection } from "astro:content";

import PagesPhotos from "./Index.vue";

const { entries, cacheHint } = await getLiveCollection("photos");

if (Astro.cache.enabled) Astro.cache.set({ ...cacheHint, maxAge: YEAR });
---

<PagesPhotos client:only data={entries ?? []}>
  <ul class="gap-4 grid grid-cols-1 md:grid-cols-2 w-full" slot="fallback">
    {
      Array.from({ length: 4 }).map(() => (
        <li class="bg-current/10 brightness-70 rounded-2xl w-full aspect-3/4" />
      ))
    }
  </ul>
</PagesPhotos>
