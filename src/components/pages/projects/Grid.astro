---
import PencilLineDuotone from "~icons/ph/pencil-line-duotone";
import PackageDuotone from "~icons/ph/package-duotone";
import ArrowUpRightIcon from "~icons/ph/arrow-up-right";

import AppEffectsSpotlightCard from "../../app/effects/SpotlightCard.astro";

import ContentLink from "../../content/Link.astro";
import ContentParagraph from "../../content/Paragraph.astro";

import type { CollectionEntry } from "astro:content";

interface Props {
  data: CollectionEntry<"projects">[];
}

const { data: allProjects } = Astro.props;

import { Markdown } from "astro-remote";

import { shuffleArray } from "../../../utils/array";
import { twMerge } from "tailwind-merge";

const transformedProjects = allProjects.map((project) => ({
  ...project.data,
  icon: project.data.isDraft ? PencilLineDuotone : PackageDuotone,
}));

const showcaseProjects = shuffleArray(transformedProjects).slice(0, 6);
---

<ul class="grid gap-4 lg:grid-cols-3">
  {
    showcaseProjects.map((project, index) => (
      <li class="contents">
        <AppEffectsSpotlightCard
          data-snap-cursor
          class={twMerge(
            "group flex w-full flex-col items-start gap-y-4 rounded-2xl border border-current/30 bg-current/10 backdrop-blur-sm transition-all duration-300 hover:border-current/70",
            project.url && "cursor-pointer",
            [0, 3, 4].includes(index) && "lg:col-span-2",
          )}
          spotlightColor="var(--spotlight-color)"
        >
          {/* Project status badge and external link indicator */}
          <div class="flex w-full items-center justify-between">
            <div class="bg-primary-900/10 dark:bg-primary-100/10 inline-flex w-fit items-center gap-x-2 rounded-full px-3 py-1 max-2xl:text-sm">
              <project.icon class="size-5" />

              {project.isDraft ? "In progress" : "Completed"}
            </div>

            {/* Arrow icon shown on hover if project has external URL */}
            {project.url && (
              <ArrowUpRightIcon class="-translate-x-1 translate-y-1 scale-0 transition duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:scale-100 size-5" />
            )}
          </div>

          <p class="font-bold group-hover:font-serif group-hover:tracking-wider group-hover:italic">
            {project.displayName ?? project.name}
          </p>

          <div class="text-left">
            <Markdown
              content={project.description}
              components={{ a: ContentLink, p: ContentParagraph }}
            />
          </div>
        </AppEffectsSpotlightCard>
      </li>
    ))
  }
</ul>
