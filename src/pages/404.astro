---
import LayoutBase from "../layouts/Base.astro";

import ContentH1 from "../components/content/H1.astro";
import ContentParagraph from "../components/content/Paragraph.vue";
---

<LayoutBase title="404">
  <section
    class="place-content-center grid min-h-screen text-center col-[2/12] xl:col-[2/8]"
  >
    <ContentParagraph
      >Hmm, that's <i class="font-serif font-bold">weird</i>, a</ContentParagraph
    >

    <ContentH1 class="text-[10dvw]"> 404 </ContentH1>

    <ContentParagraph class="max-w-md text-pretty"
      ><i class="font-serif font-bold">Reason:</i> You tried visiting >_ {
        Astro.url.pathname
      }</ContentParagraph
    >
  </section>
</LayoutBase>
