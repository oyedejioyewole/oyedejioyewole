---
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import Themes from "astro-themes";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

import { cn } from "tailwind-variants";

import "../styles/global.css";

import CursorTracking from "../components/app/effects/CursorTracking.astro";
import PathTransition from "../components/app/effects/PathTransition.astro";
import AppFooter from "../components/app/Footer.astro";
import AppNavigation from "../components/app/Navigation.astro";

interface Props {
  title: string;
  description?: string;
  class?: string;
}
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <Seo
      description={Astro.props.description}
      title={`${Astro.props.title} · Oyedeji Oyewole`}
      extraLinks={[
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
        { rel: "icon", href: "/favicon.ico" },
      ]}
    />

    <ClientRouter />

    <Themes />

    <Font cssVariable="--font-croissant-one" />
    <Font cssVariable="--font-playfair-display" />
    <Font cssVariable="--font-poppins" />
  </head>
  <body
    class="bg-primary-100 selection:bg-current/20 dark:bg-primary-900 overflow-x-hidden text-primary-700 dark:text-primary-300 cursor-crosshair"
  >
    <CursorTracking />
    <PathTransition />

    <div class="grid grid-cols-5">
      <!-- Left Sidebar -->
      <AppNavigation />

      <!-- Content -->
      <main class="col-span-full xl:col-span-4">
        <section
          class={cn(
            "grid grid-cols-12 xl:grid-cols-8 min-h-[calc(96dvh-46px)] xl:min-h-dvh",
            Astro.props.class,
          )}
        >
          <slot />
        </section>

        <!-- Footer -->
        {Astro.url.pathname !== "/" && <AppFooter />}
      </main>
    </div>
  </body>
</html>
